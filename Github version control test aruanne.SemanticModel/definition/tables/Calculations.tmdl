/// Mõõdikute kaust
table Calculations
	lineageTag: beddccab-aa39-4ac8-bca8-df4650ad69e1

	measure Blank =
			
			BLANK ()
		formatString: 0
		displayFolder: #Other
		lineageTag: e443383f-fdbd-433e-b771-5fa8447ce31e

	measure 'Avg. Response Time (Working Day Hours)' =
			
			AVERAGE ( '# incident'[WorkingDayHours] )
		formatString: 0
		displayFolder: #Calculations
		lineageTag: 80e7f362-6d2b-4a33-990c-c2529b9c4f78

	measure Label_Days/Hours =
			
			VAR ResponseTime = [Avg. Response Time (Working Day Hours)]
			VAR Days =
			    INT ( DIVIDE ( ResponseTime, 24 ) )
			VAR Hours =
			    MOD ( INT ( ResponseTime ), 24 )
			RETURN
			    IF ( NOT ISBLANK ( ResponseTime ), Days & "d & " & Hours & "h", BLANK () )
		displayFolder: #Labels_Titles\Labels
		lineageTag: 5cfeed28-7e68-4e67-87e2-3349441cf73b

	measure 'Count of cases' =
			
			COUNTROWS ( '# incident' )
		formatString: #,0
		displayFolder: #Calculations
		lineageTag: 1ae72074-8ce8-41c5-99a6-691dc19bddea

	measure Label_Days/Hours/cases =
			
			INT ( [Avg. Response Time (Working Day Hours)] / 24 ) & "d/"
			    & MOD ( INT ( [Avg. Response Time (Working Day Hours)] ), 24 ) & "h "
			    & IF (
			        NOT ( ISBLANK ( [Count of cases] ) ),
			        "(" & [Count of cases] & " cases)",
			        BLANK ()
			    )
		displayFolder: #Labels_Titles\Labels
		lineageTag: 3fc438b4-5a5b-4cd9-81a1-87d229179775

	measure 'Count of cases YoY Change' =
			
			VAR CurrentYear = [Count of cases]
			VAR _PreviousYear =
			    CALCULATE ( [Count of cases], SAMEPERIODLASTYEAR ( 'Date'[Date] ) )
			RETURN
			    CurrentYear - _PreviousYear
		formatString: +# ##0;-# ##0;0
		displayFolder: #Calculations
		lineageTag: c28ce2cf-276b-4996-a47a-339e94f36d3e

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Title_Detail table' =
			
			SWITCH (
			    USERCULTURE (),
			    "et-EE", "Detail tabel",
			    "en-US", "Detail table",
			    "Detail table"
			)
		displayFolder: #Labels_Titles\Titles
		lineageTag: 6c8645ab-baed-437d-b680-4ee1d56579e8

	measure 'Last refresh' =
			
			FORMAT ( VALUES ( 'Last Refresh'[Date Last Refreshed] ), "dd.mm.yyyy hh:mm" )
		displayFolder: #Other
		lineageTag: 7d41d4af-91ec-4f83-823a-03543e3ec9b1

	measure 'Title_Avg. response time columnchart title' =
			
