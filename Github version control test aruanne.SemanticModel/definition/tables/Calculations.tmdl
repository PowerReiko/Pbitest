			    USERCULTURE (),
			    "et-EE",
			        "• Esmareageerimise aja arvutamisel on välja jäetud nädalavahetused ja riigipühad",
			    "en-US",
			        "• Weekends and public holidays are excluded from the first response time calculation",
			    "• Weekends and public holidays are excluded from the first response time calculation"
			)
		displayFolder: #Labels_Titles\Labels
		lineageTag: d5830546-6c09-4919-8929-54771c8ebfc6

	measure Subtitle_Table =
			
			SWITCH (
			    USERCULTURE (),
			    "et-EE", "Mitme tulba sortimiseks hoia all 'Shift'",
			    "en-US", "To sort multiple columns, hold down 'Shift'",
			    "To sort multiple columns, hold down 'Shift'"
			)
		displayFolder: #Labels_Titles\Titles
		lineageTag: 805cf5dc-58cb-4e97-86cd-1305ca971a30

	measure Target =
			
			SWITCH (
			    USERCULTURE (),
			    "et-EE", "2 tööpäeva",
			    "en-US", "2 workdays",
			    "2 workdays"
			)
		displayFolder: #Other
		lineageTag: 5436a1c4-9bb9-4214-9bd7-90dbc4ac3d27

	measure 'Avg.response time color' =
			
			IF ( [Avg. Response Time (Working Day Hours)] >= 48, "#FF6400", "#2E3844" )
		displayFolder: #Other
		lineageTag: 35f28f3c-3edb-41e0-8d8d-660a35816aae

	measure 'Only relevant values' =
			
			INT ( NOT ISEMPTY ( '# incident' ) )
		formatString: 0
		displayFolder: #Other
		lineageTag: bc352f32-8fe4-429d-895f-2d566f5a1a48

	measure 'Avg.response time color (Columns)' =
			
			IF ( [Avg. Response Time (Working Day Hours)] >= 48, "#B0B1B3", "#2E3844" )
		displayFolder: #Other
		lineageTag: a25c2d7b-de49-4601-bf1f-46a78c20187a

	measure Icon_Condition =
			
			MAXX (
			    '# incident',
			    IF (
			        ( '# incident'[statecodename] = "Active" )
			            && ISBLANK ( '# incident'[First Response Sent On] )
			            && [Avg. Response Time (Working Day Hours)] <= 48,
			        1,
			        IF ( [Avg. Response Time (Working Day Hours)] <= 48, 2, 3 )
			    )
			)
		formatString: 0
		displayFolder: #Other
		lineageTag: 8399e931-e6f0-4528-ba30-ce0a626afda9

	measure '% Response W.I 22 Working Days' =
			
			VAR TotalResponses =
			    COUNTROWS ( '# incident' )
			VAR ResponsesWithin2Days =
			    CALCULATE (
			        COUNTROWS ( '# incident' ),
			        '# incident'[Response in time] = "within 2 working days"
			    )
			RETURN
			    DIVIDE ( ResponsesWithin2Days, TotalResponses, 0 )
		formatString: 0%;-0%;0%
		displayFolder: #Calculations
		lineageTag: d913f7eb-e43d-41cc-884a-293893ed0b84

	measure Count_of_Cases_Description =
			
			SWITCH (
			    USERCULTURE (),
			    "et-EE", "Pöördumiste arv ServiceDesk'is valitud perioodil",
			    "en-US", "The count of cases in ServiceDesk during the selected period",
			    "The count of cases in ServiceDesk during the selected period"
			)
		displayFolder: #Labels_Titles\Labels
		lineageTag: 58aa5207-5b95-4de7-ac0f-ed5252652d48

	measure Target_Description =
			
			SWITCH (
			    USERCULTURE (),
			    "et-EE", "Seatud eesmärk juhtkonna poolt",
			    "en-US", "The goal set by the management",
			    "The goal set by the management"
			)
		displayFolder: #Labels_Titles\Labels
		lineageTag: f4955c82-bf42-4abd-b8bc-65793fabc38b

	measure 'AVG. Respone_Time_Description' =
			
			SWITCH (
			    USERCULTURE (),
			    "et-EE", "Keskmine esmareageerimise aeg ServiceDesk'i pöördumistele päevades/tundides",
			    "en-US", "Average first response time in days/hours for ServiceDesk cases",
			    "Average first response time in days/hours for ServiceDesk cases"
			)
		displayFolder: #Labels_Titles\Labels
		lineageTag: ed69ceab-6896-416d-a83f-4f352fe7a422

	measure 'filter icon' =
			
			"data:image/png;base64,"
		displayFolder: #Other\Filter Display
		lineageTag: a425ba9f-4010-450b-9184-5c0f876d903e

	measure 'Number of Filters' =
			
			FORMAT (
			    IF ( ISFILTERED ( '# incident'[Case Type] ), 1 )
			        + IF ( ISFILTERED ( '# incident'[Warranty] ), 1 )
			        + IF ( ISFILTERED ( '≡ account'[Internal/External] ), 1 )
			        + IF ( ISFILTERED ( '≡ col_customerproduct'[Business Line Digital] ), 1 )
			        + IF ( ISFILTERED ( '# incident'[Response in time] ), 1 )
			        + IF ( ISFILTERED ( '≡ account'[Account Name] ), 1 )
			        + IF ( ISFILTERED ( '≡ account'[Owner] ), 1 )
			        + IF ( ISFILTERED ( '# incident'[statuscodename] ), 1 )
			        + IF ( ISFILTERED ( '# incident'[Sub Status] ), 1 ),
			    "#"
			)
		displayFolder: #Other\Filter Display
		lineageTag: 17b59698-ab73-4460-a8c6-8138fdcc926c

	measure 'Is filtered black' =
			
			IF ( [Number of Filters] = "", "#FFFFFF00", "#111111" )
		displayFolder: #Other\Filter Display
		lineageTag: 172b5299-1c1a-48b5-a024-59799b15a8b0

	measure 'Is filtered Green' =
			
			IF ( [Number of Filters] = "", "#FFFFFF00", "#C8FFCE" )
		displayFolder: #Other\Filter Display
		lineageTag: 3cd58c47-352e-44f0-abfd-b2ce4a1ea5ac

	partition Calculations = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i45WMlSKjQUA", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Column1", Int64.Type}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Changed Type",{"Column1"})
				in
				    #"Removed Columns"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

