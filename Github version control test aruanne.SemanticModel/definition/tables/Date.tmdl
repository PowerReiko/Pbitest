	column IsWorkingDay =
			
			IF('Date'[IsWeekend] || 'Date'[IsHoliday],
			FALSE(),
			TRUE()
			)
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 33da0cb8-9fdd-4374-8218-b0f844b54119
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition Date = calculated
		mode: import
		source = ```
				
				VAR algkpv1 = MAX(FromDate[FromDate])
				VAR loppkpv1 = MAX(FutureDate[FutureDate])
				VAR algkpv = DATE(LEFT(algkpv1,4),MID(algkpv1,5,2),RIGHT(algkpv1,2))
				VAR loppkpv = DATE(LEFT(loppkpv1,4),MID(loppkpv1,5,2),RIGHT(loppkpv1,2))
				VAR BaseCalendar =
				   	  CALENDAR(algkpv,loppkpv)
				RETURN
				    GENERATE (
				        BaseCalendar,
				        VAR BaseDate = [Date]
				        VAR Quarternum = FORMAT( BaseDate, "q" )
				        VAR QuarterRome = SWITCH ( Quarternum, "1", "I", "2", "II", "3", "III", "4", "IV")
						VAR RelDay = IF(BaseDate> TODAY(),(DATEDIFF(TODAY(),BaseDate, DAY )),-1 *(DATEDIFF(BaseDate,TODAY(), DAY )))
						VAR RelMonth =  IF(BaseDate> TODAY(),(DATEDIFF(TODAY(),BaseDate, MONTH )),-1 *(DATEDIFF(BaseDate,TODAY(), MONTH )))
						VAR RelYear = IF(BaseDate> TODAY(),(DATEDIFF(TODAY(),BaseDate, YEAR )),-1 *(DATEDIFF(BaseDate,TODAY(), YEAR )))
				        VAR YearWeek = IF(WEEKNUM(BaseDate,21) >= 52 && MONTH ( BaseDate ) = 1, YEAR ( BaseDate ) - 1, YEAR ( BaseDate ))  * 100 + WEEKNUM(BaseDate,21)
				        
				        RETURN ROW (
				            "Date d.mm.yy" , Format(BaseDate,"d.MM.yy"),
				            "Date d.mm", Format(BaseDate,"d.MM"),
				            "Monthdate", MONTH ( BaseDate ) * 100 + DAY(BaseDate),
				            "Weekday", Format(BaseDate,"ddd"),
				            "Weekday num", WEEKDAY(BaseDate,2),
				            "Week num" , WEEKNUM(BaseDate,21),
				            "Week" , WEEKNUM(BaseDate,21) & "/" & FORMAT(BaseDate,"yy"),
				            "Month mmm yy" , FORMAT ( BaseDate, "mmm yy" ),
				            "Month" , FORMAT ( BaseDate, "m-yy" ),
				            "Month number", MONTH ( BaseDate ),
				            "Month name", FORMAT ( BaseDate, "mmmm" ),
				            "Month day", DAY(BaseDate),
				            "Quarter", QuarterRome & "-" & RIGHT(FORMAT(BaseDate, "ddyy"),2),
				            "Yearweek" , YearWeek,
				            "Yearmonth", YEAR ( BaseDate ) * 100 + MONTH ( BaseDate ) ,
							"Yearquarter", Format(BaseDate,"yyyyq"),
				            "Year", YEAR ( BaseDate ),
				            "Relative day", RelDay,
				            "Relative month", RelMonth,
							"Relative year", RelYear,
				            "IsHoliday", IF(CONTAINS(FILTER('Public holidays', 'Public holidays'[DayTypeName] = "StateHoliday"),'Public holidays'[TRANSDATE],BaseDate),TRUE,FALSE()),
				            "IsWeekend", IF(WEEKDAY(BaseDate, 2) > 5, TRUE(), FALSE())
				            )
				    )
				```

	annotation PBI_Id = 1f3c9f85bd454f22b4fd7cdd252bf191

