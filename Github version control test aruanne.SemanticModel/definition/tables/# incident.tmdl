	/// Töö oleku muutmise viimane aeg
	column 'Modified On'
		dataType: dateTime
		formatString: dd.mm.yyyy hh:nn:ss
		lineageTag: 8f1e3d02-af16-448e-b322-45a2cacdb807
		summarizeBy: none
		sourceColumn: modifiedon

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	/// Tööle reageerimise aeg tundides tööpäeviti (nädalavahetused ja riigipühad arvestatakse välja)
	column WorkingDayHours =
			
			VAR Created = '# incident'[Created On]
			VAR _Status = '# incident'[statecodename]
			VAR Resolution = '# incident'[Resolution Date]
			VAR Modified = '# incident'[Modified On]
			VAR FirstResponse = '# incident'[First Response Sent On]
			VAR Response =
			    IF (
			        ISBLANK ( FirstResponse ),
			        SWITCH (
			            TRUE (),
			            _Status = "Resolved"
			                && NOT ISBLANK ( Resolution ), Resolution,
			            _Status = "Canceled"
			                && NOT ISBLANK ( Modified ), Modified,
			            NOW ()
			        ),
			        FirstResponse
			    )
			VAR DateTimes =
			    FILTER (
			        ADDCOLUMNS (
			            'Date',
			            "WorkingDayHour",
			                SWITCH (
			                    TRUE (),
			                    'Date'[Date] = DATEVALUE ( Created )
			                        && 'Date'[Date] = DATEVALUE ( Response ), DATEDIFF ( Created, Response, HOUR ),
			                    'Date'[Date] = DATEVALUE ( Created ), 24 - HOUR ( Created ),
			                    'Date'[Date] = DATEVALUE ( Response ), HOUR ( Response ),
			                    'Date'[Date] > DATEVALUE ( Created )
			                        && 'Date'[Date] < DATEVALUE ( Response ), 24,
			                    TRUE (), 0
			                )
			        ),
			        'Date'[Date] >= DATEVALUE ( Created )
			            && 'Date'[Date] <= DATEVALUE ( Response )
			            && 'Date'[IsWorkingDay] = TRUE
			    )
			RETURN
			    SUMX ( DateTimes, [WorkingDayHour] )
		formatString: 0
		lineageTag: 8026db41-9e7b-4987-ada2-94a4fc2234a2
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Kliendi ID
	column customerid
