	/// Tööde grupeeringu veerg, kus määratakse ära, kas tööle on reageeritud all 48 tunni jooksul või üle
	column 'Response in time' =
			IF (
			    '# incident'[WorkingDayHours] <= 48,
			    "within 2 working days",
			    "later than within 2 working days"
			)
		lineageTag: b992dc2c-2ebc-4482-bcf7-4b1ec3341b65
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

