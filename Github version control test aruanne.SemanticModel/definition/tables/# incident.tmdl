	partition '# incident' = m
		mode: import
		queryGroup: Fact_Data
		source =
				let
				    Source = CommonDataService.Database(Server_Dataverse, [CreateNavigationProperties=false]),
				    dbo_incident = Source{[Schema="dbo",Item="incident"]}[Data],
				    #"Removed Other Columns" = Table.SelectColumns(dbo_incident,{"title", "createdon", "ticketnumber", "modifiedon", "customerid", "customeridname", "owneridname", "statecodename", "casetypecodename", "statuscodename", "adx_resolutiondate", "col_customerproduct", "col_substatusname", "col_warrantyname", "oxd_firstresponsesenton"}),
				    #"Inserted Date" = Table.AddColumn(#"Removed Other Columns", "Date", each DateTime.Date([createdon]), type date),
				    #"Date FILTER" = Table.SelectRows(#"Inserted Date", each [Date] > #date(2024, 12, 31)),
				    #"Case Type FILTER" = Table.SelectRows(#"Date FILTER", each ([casetypecodename] = "P1 issue" or [casetypecodename] = "Request")),
				    #"""First Response"" date column add" = Table.AddColumn(#"Case Type FILTER", "First Response", each if [oxd_firstresponsesenton] <> null then [oxd_firstresponsesenton]
				else if [adx_resolutiondate] <> null then [adx_resolutiondate]
				else if [oxd_firstresponsesenton] = null and [adx_resolutiondate] = null and [statecodename] = "Canceled" then [modifiedon]
				else null),
				    #"Changed Type" = Table.TransformColumnTypes(#"""First Response"" date column add",{{"First Response", type datetime}})
				in
				    #"Changed Type"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

