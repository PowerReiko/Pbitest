cultureInfo en-US
	translations
		model Model
			table Calculations
				measure 'Avg. Response Time (Working Day Hours)'
					caption: Avg. Response time (Working day hours)
				measure Label_Days/Hours
					caption: Response Time
				measure 'Count of cases'
					caption: Count of Cases
				measure Label_Days/Hours/cases
					caption: Avg. Response Time (cases)
				measure Target
					caption: Target
				measure '% Response Within 2 Working Days'
					caption: % Response Within 2 Working Days
			table Date
				column Month
					caption: Month
			table '# incident'
				column 'Case Title'
					caption: Case Title
				column 'Created On'
					caption: Created On
				column 'Case Number'
					caption: Case Nr.
				column Customer
					caption: Customer
				column Owner
					caption: Case Owner
				column statecodename
					caption: State
				column 'First Response Sent On'
					caption: First Response
				column statuscodename
					caption: Status
				column 'Sub Status'
					caption: Sub Status
				column 'First Response'
					caption: First Response
				column 'Response in time'
					caption: First response time
				column 'Case Type'
					caption: Case Type
				column Warranty
					caption: Warranty
			table '≡ account'
				column 'Account Name'
					caption: Customer
				column Owner
					caption: CRM
				column Internal/External
					caption: Internal/External
			table '≡ col_customerproduct'
				column Name
					caption: Customer
				column 'Business Line Digital'
					caption: Business Line

